        <script><![CDATA[(function() {

    // Total Patients
    var patientGR = new GlideRecord('x_1954503_smartc_0_patient');
    patientGR.query();
    data.totalPatients = patientGR.getRowCount();

    // Admitted Patients
    var admittedGR = new GlideRecord('x_1954503_smartc_0_patient');
    admittedGR.addQuery('status', 'Admitted');
    admittedGR.query();
    data.admittedPatients = admittedGR.getRowCount();

    // Total Doctors
    var doctorGR = new GlideRecord('sys_user');
    doctorGR.addQuery('title', 'Doctor'); // adjust if needed
    doctorGR.query();
    data.totalDoctors = doctorGR.getRowCount();

})();]]></script>
